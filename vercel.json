{
  "version": 2,
  "buildCommand": "cd web && npm install && npm run build || true",
  "deployCommand": "cd web && npm run start",
  "outputDirectory": "web",
  "env": {
    "SUPABASE_URL": "@supabase_url",
    "SUPABASE_ANON_KEY": "@supabase_anon_key",
    "NODE_ENV": "production"
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
