{
  "name": "cro-analyzer-web",
  "version": "1.0.0",
  "description": "CRO Analysis Dashboard with Supabase + Vercel",
  "main": "server/server.js",
  "scripts": {
    "dev": "next dev & node server/server.js",
    "build": "next build",
    "start": "next start",
    "start:server": "node server/server.js",
    "schedule": "node server/scheduler.js",
    "deploy": "vercel --prod",
    "setup-db": "node server/scripts/setup-db.js",
    "seed": "node server/scripts/seed-data.js",
    "dev:full": "concurrently \"next dev\" \"node server/server.js\""
  },
  "keywords": [
    "cro",
    "conversion-rate-optimization",
    "analytics",
    "supabase",
    "vercel"
  ],
  "author": "CRO Analytics",
  "license": "MIT",
  "dependencies": {
    "next": "^14.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "@supabase/supabase-js": "^2.38.0",
    "node-schedule": "^2.1.1",
    "uuid": "^9.0.0",
    "plotly.js": "^2.26.0",
    "react-plotly.js": "^2.12.0",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "concurrently": "^8.2.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": "18.x"
  }
}
