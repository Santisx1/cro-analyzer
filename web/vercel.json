{
  "version": 2,
  "buildCommand": "npm run build || true",
  "devCommand": "npm run dev",
  "env": {
    "SUPABASE_URL": "@supabase_url",
    "SUPABASE_ANON_KEY": "@supabase_anon_key",
    "SUPABASE_SERVICE_KEY": "@supabase_service_key",
    "NODE_ENV": "production"
  },
  "functions": {
    "server/server.js": {
      "runtime": "nodejs18.x",
      "memory": 1024,
      "maxDuration": 60
    },
    "server/scheduler.js": {
      "runtime": "nodejs18.x",
      "memory": 512,
      "maxDuration": 300
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server/server.js"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=3600"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
