# Variáveis de ambiente para CRO Analyzer Web

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# Server Configuration
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://...

# Analysis Settings
MIN_ABANDONMENT_THRESHOLD=20
MIN_RECOMMENDATION_SCORE=0.5

# Scheduler
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=America/Sao_Paulo
SCHEDULER_HOUR=2
SCHEDULER_MINUTE=0

# Email Notifications (Optional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
NOTIFICATIONS_EMAIL=recipient@gmail.com

# Google Analytics (Optional)
GA4_PROPERTY_ID=123456789
GA4_CREDENTIALS_PATH=./credentials.json

# Heatmap Providers (Optional)
CLARITY_PROJECT_ID=your_clarity_id
HOTJAR_SITE_ID=your_hotjar_id

# API Keys (Optional)
OPENAI_API_KEY=sk-...
